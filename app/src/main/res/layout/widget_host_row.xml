<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/widget_row_surface"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <TextView
        android:id="@+id/widget_host_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/color_widget_text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_btn_ssh"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/widget_action_primary_background"
            android:contentDescription="@string/widget_action_ssh"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_widget_terminal"
            android:tint="@color/color_widget_text_primary" />

        <ImageView
            android:id="@+id/widget_btn_sftp"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_action_secondary_background"
            android:contentDescription="@string/widget_action_sftp"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_widget_cloud_download"
            android:tint="@color/color_widget_text_primary" />

        <ImageView
            android:id="@+id/widget_btn_scp"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_action_secondary_background"
            android:contentDescription="@string/widget_action_scp"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_widget_cloud_download"
            android:tint="@color/color_widget_text_primary" />
    </LinearLayout>

</LinearLayout>
