<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/widget_row_surface"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <TextView
        android:id="@+id/widget_open_session_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/color_widget_text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/widget_btn_open"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/widget_action_primary_background"
        android:contentDescription="@string/widget_action_open_session"
        android:padding="7dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_widget_open"
        app:tint="@color/color_widget_text_primary" />

    <ImageView
        android:id="@+id/widget_btn_disconnect"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/widget_action_danger_background"
        android:contentDescription="@string/widget_action_disconnect_session"
        android:padding="7dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_widget_close"
        app:tint="@color/color_widget_text_primary" />

</LinearLayout>
