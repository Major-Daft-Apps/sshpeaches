<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid backdrop to prevent launcher tint/halo from showing through -->
    <item android:drawable="@color/ic_launcher_background" />

    <!-- Inset the artwork heavily to avoid cropping and ring artifacts -->
    <item
        android:drawable="@drawable/sshpeaches"
        android:insetLeft="28dp"
        android:insetTop="28dp"
        android:insetRight="28dp"
        android:insetBottom="28dp" />
</layer-list>
